# Snipe-IT API — point at the Docker-internal URL of your existing Snipe-IT
# service (e.g. http://snipe-it:80). Do NOT use the public/Tailscale URL here;
# the MCP container reaches Snipe-IT over the shared internal Docker network.
SNIPEIT_URL=http://snipe-it:80
SNIPEIT_TOKEN=paste-snipe-it-api-token-here

# Curated tool set. Covers create/read/update flow for assets, consumables,
# accessories, components, plus the metadata Claude needs to autofill new items.
# Destructive admin tools are intentionally omitted — add as you need them.
SNIPEIT_ALLOWED_TOOLS=manage_assets,asset_operations,manage_models,manage_manufacturers,manage_categories,manage_locations,manage_status_labels,manage_users,manage_consumables,manage_accessories,accessory_operations,manage_components,component_operations,manage_suppliers,manage_companies,manage_departments,manage_fields,manage_fieldsets,status_summary,activity_reports

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# Chainlit signs session cookies with this. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CHAINLIT_AUTH_SECRET=replace-me
