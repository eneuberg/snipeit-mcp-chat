# ==== AUTH ==================================================================
# This stack uses your host's `claude login` OAuth session (bind-mounted from
# ~/.claude into the webui container). API-key auth isn't wired up — see the
# README if you want to add it back.
#
# Rate limits on the subscription path are tuned for interactive use — fine
# for snapping the occasional photo from your phone, not for bulk imports.

# Where `claude login` wrote your OAuth session on the host. On Linux
# that's ~/.claude/.credentials.json + ~/.claude.json. Both default to
# the invoking shell's ${HOME} — only override when the compose
# process doesn't run as that user (snap Docker, sudo-invoked compose,
# Coolify — there ${HOME} is often /root or a Coolify-internal path
# and you need to point at the real user's home, e.g.
# /home/erikli-pi/.claude).
#
# The files are bind-mounted read-only into webui and forked on first
# boot into a named volume. One-time host setup is `claude login` +
# `claude mcp add snipeit ...`.
#CLAUDE_HOST_DIR=/home/youruser/.claude
#CLAUDE_CONFIG_FILE=/home/youruser/.claude.json

# ==== Snipe-IT API ==========================================================
# Point at the Docker-internal URL of your existing Snipe-IT service
# (e.g. http://snipe-it:80). Not the public/Tailscale URL — the MCP container
# reaches Snipe-IT over the shared internal Docker network.
SNIPEIT_URL=http://snipe-it:80
SNIPEIT_TOKEN=paste-snipe-it-api-token-here

# Curated tool set. Covers create/read/update for assets, consumables,
# accessories, components + metadata Claude needs to autofill new items.
# Photo-upload helpers:
#   `asset_files`     — puts the file on the asset's Files tab
#   `asset_thumbnail` — sets the asset's main image (header + list views);
#                       added by our local Dockerfile extension
# Destructive admin tools are intentionally omitted — add as you need them.
SNIPEIT_ALLOWED_TOOLS=manage_assets,asset_operations,asset_files,asset_thumbnail,manage_models,manage_manufacturers,manage_categories,manage_locations,manage_status_labels,manage_users,manage_consumables,manage_accessories,accessory_operations,manage_components,component_operations,manage_suppliers,manage_companies,manage_departments,manage_fields,manage_fieldsets,status_summary,activity_reports
