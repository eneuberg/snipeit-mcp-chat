# ==== AUTH MODE — pick ONE ==================================================
# (A) API-key mode: set ANTHROPIC_API_KEY below. Per-token billing, no extra
#     setup needed on the host.
# (B) Subscription mode: LEAVE ANTHROPIC_API_KEY BLANK and run `claude login`
#     on the host first. The chat container bundles the Claude Code CLI and
#     reuses your host's OAuth session via the ~/.claude bind mount in
#     docker-compose.yml.
#
# Rate limits in subscription mode are tuned for interactive use — fine for
# snapping the occasional photo from your phone, not for bulk imports.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# Override these if your Claude Code creds don't live at the invoking
# user's ~/.claude (e.g. snap Docker where ${HOME} resolves to the snap's
# private home, Coolify, sudo-invoked compose). Both default to the
# shell's ${HOME} when left unset.
#
# These are bind-mounted read-only into the webui container on first
# boot; the container then forks its own copy into a named volume. You
# only need `claude login` + `claude mcp add snipeit ...` on the host
# once before the first build.
#CLAUDE_HOST_DIR=/home/youruser/.claude
#CLAUDE_CONFIG_FILE=/home/youruser/.claude.json

# ==== Snipe-IT API ==========================================================
# Point at the Docker-internal URL of your existing Snipe-IT service
# (e.g. http://snipe-it:80). Not the public/Tailscale URL — the MCP container
# reaches Snipe-IT over the shared internal Docker network.
SNIPEIT_URL=http://snipe-it:80
SNIPEIT_TOKEN=paste-snipe-it-api-token-here

# Curated tool set. Covers create/read/update for assets, consumables,
# accessories, components + metadata Claude needs to autofill new items.
# Destructive admin tools are intentionally omitted — add as you need them.
SNIPEIT_ALLOWED_TOOLS=manage_assets,asset_operations,manage_models,manage_manufacturers,manage_categories,manage_locations,manage_status_labels,manage_users,manage_consumables,manage_accessories,accessory_operations,manage_components,component_operations,manage_suppliers,manage_companies,manage_departments,manage_fields,manage_fieldsets,status_summary,activity_reports

